rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - Public read for profiles, but only users write their own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Subcollections (inventory, meta)
      match /inventory/{itemId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
      match /meta/{document} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Items collection - public read access for item definitions
    match /items/{itemId} {
      allow read: if true;
      allow write: if false;
    }

    // Listings collection - authenticated users can read all listings
    match /listings/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.seller == request.auth.uid
                    && request.resource.data.price is int
                    && request.resource.data.price > 0
                    && request.resource.data.itemId is string
                    && request.resource.data.itemId.size() > 0;
      allow update, delete: if request.auth != null &&
                               request.auth.uid == resource.data.seller;
    }
  }
}
